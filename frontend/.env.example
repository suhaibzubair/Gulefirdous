REACT_APP_GULEFIRDOUS_API_BASE_URL=http://localhost:4000

# Auth mode: auto | mock | firebase
# auto uses Firebase when keys are present, otherwise mock auth for local dev/tests
REACT_APP_AUTH_MODE=auto

# Firebase Authentication (Google + phone OTP)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
